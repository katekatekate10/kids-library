---
import '../styles/app.css';
interface Props {
  title?: string;
}
const { title = "Kids' Library" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f1e6" />
    <title>{title}</title>

    <!-- PWA: installable from any modern browser; shell works offline once visited.
         crossorigin="use-credentials" tells the browser to send the
         Cloudflare Access cookie when fetching the manifest. Without it,
         Access 302s the manifest fetch and the install affordance silently
         breaks. The icons referenced inside the manifest inherit the
         manifest fetch's credentials mode, so they get the cookie too.
         The plain favicon link below doesn't take crossorigin — its 302
         just means no tab icon shows for unauthenticated requests, which
         doesn't happen in practice anyway. -->
    <link rel="manifest" href="/manifest.webmanifest" crossorigin="use-credentials" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <!-- iOS-specific: hide the Safari chrome when launched from home screen. -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Kids' Library" />

    <script src="https://unpkg.com/@zxing/browser@0.2.0/umd/zxing-browser.min.js" defer></script>

    <!-- Service worker registration. Inline so it runs ASAP without
         waiting on the app bundle. The handler is forgiving: a 404
         on /sw.js during local dev would just no-op. -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => {
            // Don't surface to user — SW is a progressive enhancement,
            // not load-bearing. Console for debugging.
            console.warn('SW registration failed:', err);
          });
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
