---
interface Props {
  title?: string;
}
const { title = "Kids' Library" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f1e6" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light; --bg: #f7f1e6; --ink: #2a2118; --muted: #7a6f63; --accent: #b85c38; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        font-size: 16px; line-height: 1.45; }
      main { padding: 24px 18px; max-width: 720px; margin: 0 auto; }
      h1 { margin: 0 0 6px 0; font-size: 22px; letter-spacing: -0.01em; }
      .tagline { color: var(--muted); font-size: 13px; margin: 0 0 18px 0; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
