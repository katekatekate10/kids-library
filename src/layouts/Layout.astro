---
import '../styles/app.css';
interface Props {
  title?: string;
}
const { title = "Kids' Library" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f7f1e6" />
    <title>{title}</title>
    <script src="https://unpkg.com/@zxing/browser@0.2.0/umd/zxing-browser.min.js" defer></script>
  </head>
  <body>
    <slot />
  </body>
</html>
