---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <main>
    <h1>Kids' Library</h1>
    <p class="tagline">Scaffold is up. Data layer is next.</p>
    <p>Signed in as <b id="email">(loading…)</b>.</p>
    <p style="color: var(--muted); margin-top: 24px;">
      The old app is still live at
      <a href="https://falkizar.github.io/kids-library/">falkizar.github.io/kids-library</a>
      until we explicitly deprecate it.
    </p>
    <script is:inline>
      fetch('/api/me')
        .then((r) => r.json())
        .then((d) => {
          document.getElementById('email').textContent = d.email || '(no email header)';
        })
        .catch(() => {
          document.getElementById('email').textContent = '(api error)';
        });
    </script>
  </main>
</Layout>
